<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>desktop_workspace</id>
    <name>Desktop Workspace</name>
    <summary>Open Nextcloud apps in a desktop-style workspace.</summary>
    <description><![CDATA[Desktop Workspace adds a browser-contained workspace to Nextcloud with app windows, a taskbar, app pinning, desktop icons, saved window/app-menu/icon state, and optional desktop-folder/file-manager features.

Admins can enable the app like any other Nextcloud app and configure the experimental file manager, multiple-window behavior, debug logging, and per-user resets from the Desktop Workspace admin settings. Users can adjust their own desktop icons, desktop folder, experimental opt-ins, window state, and reset options from the Desktop personal settings.]]></description>
    <version>0.14.4</version>
    <licence>AGPL-3.0-or-later</licence>
    <author homepage="https://canisdata.de/">canisdata</author>
    <namespace>DesktopWorkspace</namespace>
    <documentation>
        <user>https://github.com/canisdata/desktop_workspace#readme</user>
        <admin>https://github.com/canisdata/desktop_workspace#readme</admin>
    </documentation>
    <category>customization</category>
    <website>https://github.com/canisdata/desktop_workspace</website>
    <bugs>https://github.com/canisdata/desktop_workspace/issues</bugs>
    <repository>https://github.com/canisdata/desktop_workspace</repository>
    <screenshot small-thumbnail="https://raw.githubusercontent.com/canisdata/desktop_workspace/main/screenshots/Desktop_in_NC_003_thumbnail.png"><![CDATA[https://raw.githubusercontent.com/canisdata/desktop_workspace/main/screenshots/Desktop_in_NC_003.png]]></screenshot>
    <dependencies>
        <nextcloud min-version="33" max-version="34" />
    </dependencies>
    <settings>
        <admin>OCA\DesktopWorkspace\Settings\Admin</admin>
        <admin-section>OCA\DesktopWorkspace\Settings\AdminSection</admin-section>
        <personal>OCA\DesktopWorkspace\Settings\Personal</personal>
        <personal-section>OCA\DesktopWorkspace\Settings\PersonalSection</personal-section>
    </settings>
    <navigations>
